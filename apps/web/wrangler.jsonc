{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pages-ashtra-ai",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": [
    "nodejs_compat",
    "enable_nodejs_sqlite_module"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
